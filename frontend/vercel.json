{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/trang-chu.html",
      "destination": "/trang-chu",
      "permanent": true
    },
    {
      "source": "/product.html",
      "destination": "/san-pham",
      "permanent": true
    },
    {
      "source": "/blog.html",
      "destination": "/bai-viet-ky-thuat",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/gioi-thieu",
      "permanent": true
    },
    {
      "source": "/activities.html",
      "destination": "/hoat-dong",
      "permanent": true
    },
    {
      "source": "/recruitment.html",
      "destination": "/tuyen-dung",
      "permanent": true
    },
    {
      "source": "/store.html",
      "destination": "/dai-ly",
      "permanent": true
    },
    {
      "source": "/detail.html",
      "has": [
        {
          "type": "query",
          "key": "id",
          "value": "(?<id>[^&]+)"
        }
      ],
      "destination": "/san-pham/:id",
      "permanent": true
    },
    {
      "source": "/blog-detail.html",
      "has": [
        {
          "type": "query",
          "key": "id",
          "value": "(?<id>[^&]+)"
        }
      ],
      "destination": "/bai-viet-ky-thuat/:id",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/trang-chu",
      "destination": "/trang-chu.html"
    },
    {
      "source": "/san-pham",
      "destination": "/product.html"
    },
    {
      "source": "/san-pham/:id",
      "destination": "/detail.html"
    },
    {
      "source": "/bai-viet-ky-thuat",
      "destination": "/blog.html"
    },
    {
      "source": "/bai-viet-ky-thuat/:id",
      "destination": "/blog-detail.html"
    },
    {
      "source": "/gioi-thieu",
      "destination": "/about.html"
    },
    {
      "source": "/hoat-dong",
      "destination": "/activities.html"
    },
    {
      "source": "/tuyen-dung",
      "destination": "/recruitment.html"
    },
    {
      "source": "/dai-ly",
      "destination": "/store.html"
    }
  ]
}
